# ─── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=your-very-secret-key-here
DEBUG=True

# ─── Database (uncomment & fill in for MySQL; SQLite is used when these are commented out) ──
# DB_NAME=usafilink_db
# DB_USER=usafilink_user
# DB_PASSWORD=strongpassword
# DB_HOST=localhost
# DB_PORT=3306

# ─── IntaSend Payment Gateway ──────────────────────────────────────────────────
# Use "production" for live, "sandbox" for testing
INTASEND_ENV=sandbox
INTASEND_PUBLIC_KEY=your_intasend_public_key_here
INTASEND_SECRET_KEY=your_intasend_secret_key_here
INTASEND_CALLBACK_URL=http://localhost:8000/api/payments/intasend/callback/

# ─── Africa's Talking (SMS) ────────────────────────────────────────────────────
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your_africastalking_api_key_here

# ─── Celery & Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── Email (Gmail SMTP) ────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here
DEFAULT_FROM_EMAIL=your_email@gmail.com
